<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Mobile dev build uses local HTTP API on LAN IP (VITE_API_URL). -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
