# --- Public (Vite / browser) ---
# Production: set to your HTTPS API origin if the SPA is hosted separately (e.g. https://api.yourdomain.com).
# Same-origin Azure deploy (Express serves dist/spa + /api): leave empty so the browser uses relative /api paths.
VITE_API_URL=
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Reception: default payment QR (served from client/public/payment-qr.png) and OTP contact display
VITE_PAYMENT_QR_URL=/payment-qr.png
VITE_OTP_PHONE=9137295344

# --- Server (Node / Express) — never expose to the browser ---
NODE_ENV=development
PORT=8080
# Azure App Service may also set WEBSITES_PORT; the server uses PORT || WEBSITES_PORT || 8080
# Azure App Service: set PORT / WEBSITES_PORT to the listening port (often 8080). Bind address:
HOST=0.0.0.0
# Canonical public URL of this app (HTTPS), used for CORS + logs. Example: https://your-app.azurewebsites.net
PUBLIC_URL=
# Optional: redirect HTTP→HTTPS when x-forwarded-proto=http (behind Azure Front Door / App Gateway). Usually not needed on App Service.
FORCE_HTTPS_REDIRECT=false

# Supabase (required for DB + Storage from the API process)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>
# Storage buckets created automatically by API if missing: "reports", "kyc-documents" (private).

# Required for signing Supabase RLS JWTs used by staff API routes (Dashboard: Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=<same-as-supabase-jwt-secret>

# App auth (access + refresh tokens issued by this API)
JWT_SECRET=<generate-32-bytes-min>
JWT_REFRESH_SECRET=<generate-32-bytes-min>

# Field encryption (if used by onboarding / profiles)
ENCRYPTION_KEY=<generate-32-bytes-min>

# CORS: browser origins allowed to call this API (comma-separated). Merged with ADMIN_URL, MOBILE_APP_URL, STAFF_PORTAL_URL, PUBLIC_URL.
# Production: list every HTTPS origin that loads your SPA(s). Example: https://admin.example.com,https://app.example.com
CORS_ORIGINS=
# In production, localhost is NOT in the default CORS list unless you set:
# CORS_ALLOW_LOCALHOST=true

# Primary deployed URLs (used in default CORS list and email/deeplinks)
# Production (Azure or other): use https://your-domain.com for each SPA/API origin you expose.
ADMIN_URL=http://localhost:8080
MOBILE_APP_URL=http://localhost:8080
STAFF_PORTAL_URL=http://localhost:8080

# Optional
PING_MESSAGE=pong
OTP_VALIDITY_MINUTES=5
OTP_MAX_ATTEMPTS=5
