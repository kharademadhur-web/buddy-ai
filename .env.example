# --- Public (Vite / browser) ---
# Production split host (admin SPA on admin.estrellx.shop, API on api.estrellx.shop):
#   VITE_API_URL=https://api.estrellx.shop
# Same-origin (Express serves dist/spa + /api on one hostname): leave VITE_API_URL empty.
VITE_API_URL=
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Reception: default payment QR (served from client/public/payment-qr.png) and OTP contact display
VITE_PAYMENT_QR_URL=/payment-qr.png
VITE_OTP_PHONE=9137295344

# --- Server (Node / Express) — never expose to the browser ---
NODE_ENV=development
PORT=8080
# Azure App Service may also set WEBSITES_PORT; the server uses PORT || WEBSITES_PORT || 8080
# Azure App Service: set PORT / WEBSITES_PORT to the listening port (often 8080). Bind address:
HOST=0.0.0.0
# Canonical public URL of this app (HTTPS), used for CORS + logs. Example: https://your-app.azurewebsites.net
PUBLIC_URL=
# Optional: redirect HTTP→HTTPS when x-forwarded-proto=http (behind Azure Front Door / App Gateway). Usually not needed on App Service.
FORCE_HTTPS_REDIRECT=false

# Supabase (required for DB + Storage from the API process)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>
# Storage buckets created automatically by API if missing: "reports", "kyc-documents" (private).

# Required for signing Supabase RLS JWTs used by staff API routes (Dashboard: Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=<same-as-supabase-jwt-secret>

# App auth (access + refresh tokens issued by this API)
JWT_SECRET=<generate-32-bytes-min>
JWT_REFRESH_SECRET=<generate-32-bytes-min>

# Field encryption (if used by onboarding / profiles)
ENCRYPTION_KEY=<generate-32-bytes-min>

# CORS: browser origins allowed to call this API (comma-separated). Merged with ADMIN_URL, MOBILE_APP_URL, STAFF_PORTAL_URL, PUBLIC_URL.
# Production: list every HTTPS origin that loads your SPA(s). Example: https://admin.example.com,https://app.example.com
CORS_ORIGINS=
# In production, localhost is NOT in the default CORS list unless you set:
# CORS_ALLOW_LOCALHOST=true

# Primary deployed URLs (used in default CORS list and credential emails / deeplinks)
# Production (Estrellx-style split):
#   ADMIN_URL=https://admin.estrellx.shop
#   STAFF_PORTAL_URL=https://admin.estrellx.shop
#   PUBLIC_URL=https://api.estrellx.shop
#   MOBILE_APP_URL=https://app.estrellx.shop
# (MOBILE_APP_URL is for CORS if you add a staff web shell; native app uses EXPO_PUBLIC_API_URL — see mobile/.env.example)
ADMIN_URL=http://localhost:8080
MOBILE_APP_URL=http://localhost:8080
STAFF_PORTAL_URL=http://localhost:8080

# --- OpenAI (optional; handwriting pad OCR via vision when set) ---
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1

# --- Anthropic Claude (optional; handwriting pad OCR when OpenAI not set or fails) ---
# https://console.anthropic.com
# ANTHROPIC_API_KEY=
# ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_BASE=https://api.anthropic.com

# --- xAI Grok (optional; consultation summary uses API when set) ---
# https://console.x.ai — OpenAI-compatible chat completions
XAI_API_KEY=
# Optional: GROK_API_KEY=XAI_API_KEY alternative name
# XAI_MODEL=grok-2-latest
# XAI_API_BASE=https://api.x.ai/v1

# --- Staff email (follow-up alerts to reception) — optional; logs only without Resend ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=SmartClinic <onboarding@resend.dev>
# Optional: always BCC this address for follow-up emails (testing / shared inbox)
# STAFF_NOTIFICATION_EMAIL=

# --- WhatsApp outbound (optional; otherwise messages are logged only) ---
# Twilio Console → Account: use Account SID (starts with AC) for the Messages API.
# Twilio Admin → My Organization: Organization SID (starts with OR) is for org/account admin; not used by this app’s WhatsApp send path.
# Optional reference only:
# TWILIO_ORGANIZATION_SID=
# Twilio WhatsApp:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional: approved Content template (ContentSid + ContentVariables) for follow-up patient messages — matches API curl style
# TWILIO_FOLLOWUP_CONTENT_SID=HXb5b62575e6e4ff6129ad7c8efe1f983e
# TWILIO_FOLLOWUP_COMPLETED_CONTENT_SID=
# Maps to template placeholders {{1}} {{2}} → JSON variables "1","2" (scheduled: date + default time; completed: date + doctor name)
# TWILIO_FOLLOWUP_TEMPLATE_VAR2_DEFAULT=3pm
# Meta WhatsApp Cloud API:
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0

# Follow-up reminders (WhatsApp day-before due_date); in-process worker
# REMINDER_WORKER_INTERVAL_MS=900000
# REMINDER_WORKER_DISABLED=true
# Production HTTP cron (optional): GET /api/messaging/cron/reminders?secret=...
# REMINDER_CRON_SECRET=

# Optional
PING_MESSAGE=pong
OTP_VALIDITY_MINUTES=5
OTP_MAX_ATTEMPTS=5
