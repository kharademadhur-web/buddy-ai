# WARNING: Do not put real keys here — this file is committed to git.
# Copy to scripts/github-actions-secrets.local.env (gitignored), fill it, then: pnpm secrets:github
#
# VITE_* = Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
#
# Azure → App Service → Get publish profile → save as publish-profile.xml in repo root
PUBLISH_PROFILE_PATH=publish-profile.xml
