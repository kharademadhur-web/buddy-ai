# Copy this file to: scripts/github-actions-secrets.local.env (gitignored)
# Fill in real values, then run: pnpm exec tsx scripts/push-github-secrets.mjs
# Or: pwsh scripts/push-github-actions-secrets.ps1
#
# VITE_* = Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
#
# Download from Azure Portal → App Service → Get publish profile
# Save the .PublishSettings file in repo root as publish-profile.xml (gitignored) OR set path below:
PUBLISH_PROFILE_PATH=publish-profile.xml
